datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedLists   List[]       @relation("ListOwner")
  sharedLists  ListShare[]
  inviteCodes  InviteCode[] @relation("InviteCreator")
}

model InviteCode {
  code      String    @id
  createdBy String
  creator   User      @relation("InviteCreator", fields: [createdBy], references: [id])
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model List {
  id            String      @id @default(cuid())
  name          String
  type          String      @default("personal") // "personal" | "shared"
  sharedWithAll Boolean     @default(false)
  ownerId       String
  owner         User        @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items  Item[]
  shares ListShare[]
}

model ListShare {
  id     String @id @default(cuid())
  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
}

model Item {
  id        String    @id @default(cuid())
  name      String
  quantity  Int       @default(1)
  checked   Boolean   @default(false)
  checkedAt DateTime?
  category  String?
  listId    String
  list      List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([listId])
  @@index([checked, checkedAt])
}
